# =============================================
# POS System Backend - Environment Configuration
# Copy this file to .env and update values
# =============================================
#
# CLOUD DEPLOYMENT CONFIGURATION
# ---------------------------------------------
# For production deployment, ensure:
# 1. Set NODE_ENV=production
# 2. Configure ALLOWED_ORIGINS for CORS
# 3. Set proper database credentials
# 4. Use strong JWT_SECRET
# 5. Configure SSL for database connections
# =============================================

# =============================================
# SERVER CONFIGURATION
# =============================================

# Environment mode: development, production, staging
NODE_ENV=development

# Server port (use process.env.PORT on cloud platforms)
PORT=5000

# Cloud platform detection (auto-detected, can override)
# Options: aws, vercel, railway, fly, self-hosted
# CLOUD_PLATFORM=aws

# Domain name for production (used in logs and API responses)
# DOMAIN=api.your-pos-domain.com

# Frontend URL for CORS (production)
# FRONTEND_URL=https://your-frontend-domain.com

# Allowed CORS origins (comma-separated for multiple origins)
# ALLOWED_ORIGINS=https://your-frontend-domain.com,https://admin.your-domain.com

# =============================================
# DATABASE CONFIGURATION
# =============================================

# Database host (use cloud DB endpoint in production)
DB_HOST=localhost

# Database port
DB_PORT=3306

# Database name
DB_NAME=pos_system

# Database user
DB_USER=root

# Database password
DB_PASSWORD=your_mysql_password

# Connection pool settings (adjust for cloud)
DB_CONNECTION_LIMIT=20
DB_QUEUE_LIMIT=0

# Timeout settings (milliseconds)
DB_CONNECT_TIMEOUT=10000
DB_ACQUIRE_TIMEOUT=10000

# Timezone
DB_TIMEZONE=+00:00

# Character set
DB_CHARSET=utf8mb4

# SSL configuration for cloud databases (set to 'true' for cloud DB)
DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false

# =============================================
# JWT CONFIGURATION
# =============================================

# JWT secret key (CHANGE IN PRODUCTION - use at least 32 characters)
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# JWT token expiration time
JWT_EXPIRES_IN=15m

# JWT refresh token expiration time
JWT_REFRESH_EXPIRES_IN=7d

# =============================================
# SECURITY & RATE LIMITING
# =============================================

# Rate limiting window in milliseconds (15 minutes default)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
# Development: 1000, Production: 500
RATE_LIMIT_MAX_REQUESTS=1000

# JSON body size limit
JSON_BODY_LIMIT=10mb

# URL encoded body size limit
URLENCODED_BODY_LIMIT=10mb

# =============================================
# APPLICATION SETTINGS
# =============================================

# Application name
APP_NAME=POS System

# Application URL
APP_URL=http://localhost:5000

# API version
API_VERSION=v1

# =============================================
# LOGGING CONFIGURATION
# =============================================

# Log level: debug, info, warn, error, silent
LOG_LEVEL=debug

# Log file path (relative to project root)
LOG_FILE_PATH=./logs

# Enable console logging
LOG_TO_CONSOLE=true

# Enable file logging
LOG_TO_FILE=true

# =============================================
# SESSION CONFIGURATION
# =============================================

# Session secret (for future session middleware)
SESSION_SECRET=your_session_secret_change_in_production

# =============================================
# CACHE CONFIGURATION (for Redis/cloud cache)
# =============================================

# Enable caching
CACHE_ENABLED=false

# Cache TTL in seconds
CACHE_TTL=300

# Redis URL (if using Redis)
# REDIS_URL=redis://localhost:6379

# =============================================
# EMAIL CONFIGURATION (for notifications)
# =============================================

# Email service provider
# MAIL_SERVICE=sendgrid
# MAIL_API_KEY=your_sendgrid_api_key
# MAIL_FROM=noreply@your-domain.com

# =============================================
# DEPLOYMENT CONFIGURATION
# =============================================

# Deployment host (for PM2 deploy)
# DEPLOY_HOST=your-server.com
# DEPLOY_SSH_PORT=22
# GIT_REPO=git@github.com:your-repo.git

# PM2 configuration
# PM2_PUBLIC_KEY=your-keymetrics-public-key
# PM2_SECRET_KEY=your-keymetrics-secret-key
# PM2_MACHINE_NAME=pos-backend-prod

# =============================================
# MONITORING & HEALTH
# =============================================

# Enable health check endpoint
ENABLE_HEALTH_CHECK=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=60

# Enable metrics collection
ENABLE_METRICS=false

# =============================================
# MAINTENANCE MODE
# =============================================

# Enable maintenance mode
MAINTENANCE_MODE=false

# Maintenance message
MAINTENANCE_MESSAGE=System maintenance in progress. Please try again later.

# =============================================
# CLOUD PLATFORM SPECIFIC
# =============================================

# For AWS:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# For Vercel:
# VERCEL=true
# VERCEL_URL=https://your-project.vercel.app

# For Railway:
# RAILWAY_STATIC_URL=https://your-project.railway.app

# For Fly.io:
# FLY_APP_NAME=pos-backend
# FLY_REGION=ord

# =============================================
# DEBUG OPTIONS
# =============================================

# Enable debug mode (development only)
DEBUG=false

# Enable SQL query logging
DB_QUERY_LOGGING=false

# Enable error stack traces
SHOW_ERROR_STACK=false
